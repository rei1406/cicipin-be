# =============================================================================
# Environment Variables Example
# Copy this file to .env (production) or .env.dev (development) and fill in
# the values. Never commit .env or .env.dev to version control.
# =============================================================================

# --- User Service DB ---
USER_SERVICE_DB_USER=cicipin
USER_SERVICE_DB_PASSWORD=change_me
USER_SERVICE_DB_NAME=user_db
USER_SERVICE_DB_HOST_PORT=7001
USER_SERVICE_DB_CONTAINER_PORT=7001

# --- User Service ---
USER_SERVICE_HOST_PORT=8081
USER_SERVICE_CONTAINER_PORT=8081

# --- API Gateway ---
API_GATEWAY_HOST_PORT=8080
API_GATEWAY_CONTAINER_PORT=8080

# --- Email Service ---
EMAIL_SERVICE_HOST_PORT=8082
EMAIL_SERVICE_CONTAINER_PORT=8082

# --- Mail (SMTP) ---
# The service is pre-configured for Gmail (smtp.gmail.com:587 with STARTTLS).
# For Gmail you must use an App Password, not your regular account password.
# Generate one at: https://myaccount.google.com/apppasswords
# (requires 2-Step Verification to be enabled on your Google account)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-char-app-password
# MAIL_FROM is the address shown in the "From" field.
# Gmail only allows sending from your own address.
MAIL_FROM=your-email@gmail.com

# --- Kafka ---
# KRaft mode (no Zookeeper). All config is externalized for flexibility.
KAFKA_HOST_PORT=9092
KAFKA_CONTAINER_PORT=9092
KAFKA_CONTROLLER_CONTAINER_PORT=9093
KAFKA_NODE_ID=1
KAFKA_PROCESS_ROLES=broker,controller
KAFKA_ADVERTISED_HOST=localhost
KAFKA_LISTENER_SECURITY_PROTOCOL_MAP=PLAINTEXT:PLAINTEXT,CONTROLLER:PLAINTEXT
KAFKA_CONTROLLER_LISTENER_NAMES=CONTROLLER
KAFKA_INTER_BROKER_LISTENER_NAME=PLAINTEXT
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1
KAFKA_LOG_DIRS=/var/lib/kafka/data

# --- App ---
APP_NAME=Cicipin
